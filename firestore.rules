rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── users collection ────────────────────────────────────────────────────
    // Anyone authenticated can read users (needed for dashboard listings).
    // Only the user themselves or an authenticated user can write their own doc.
    // Admin writes are handled server-side or via Firebase Admin SDK.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── workLogs collection ─────────────────────────────────────────────────
    match /workLogs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── leaveRequests collection ────────────────────────────────────────────
    match /leaveRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── departments collection ──────────────────────────────────────────────
    match /departments/{deptId} {
      allow read: if true; // Public read so signup page can list departments
      allow write: if request.auth != null;
    }
  }
}
